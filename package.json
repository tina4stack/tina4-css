{
  "name": "tina4-css",
  "version": "2.1.0",
  "description": "Lightweight CSS framework + Frond JS helper for server-rendered apps. Grid, buttons, forms, cards, nav, modals, alerts, AJAX, WebSocket, SSE. Zero dependencies.",
  "main": "dist/tina4.min.css",
  "style": "dist/tina4.min.css",
  "sass": "src/scss/tina4.scss",
  "files": [
    "dist/",
    "src/scss/",
    "src/js/"
  ],
  "scripts": {
    "build:frond": "esbuild src/js/frond.ts --bundle --minify --format=iife --global-name=_frondModule --outfile=dist/frond.min.js --footer:js=\"/* Frond v2 — tina4.com */\"",
    "build:frond:dev": "esbuild src/js/frond.ts --bundle --format=iife --global-name=_frondModule --outfile=dist/frond.js --sourcemap"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "keywords": [
    "css",
    "scss",
    "framework",
    "responsive",
    "grid",
    "flexbox",
    "lightweight",
    "ajax",
    "websocket",
    "sse",
    "frond",
    "tina4"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tina4stack/tina4-css.git"
  },
  "author": "Tina4 Stack",
  "license": "MIT",
  "homepage": "https://tina4.com",
  "bugs": {
    "url": "https://github.com/tina4stack/tina4-css/issues"
  }
}
