{
    "name": "tina4stack/tina4css",
    "description": "Tina4 CSS - A lightweight responsive CSS framework",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": ">=8.1",
        "scssphp/scssphp": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
